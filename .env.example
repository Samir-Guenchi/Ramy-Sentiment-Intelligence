# ============================================
# Ramy Sentiment Intelligence — Environment
# ============================================

# Model Configuration
MODEL_NAME=aubmindlab/bert-base-arabertv02
MODEL_CACHE_DIR=./models_cache
MODEL_OUTPUT_DIR=./models/checkpoints/sentiment
MAX_SEQ_LENGTH=256
BATCH_SIZE=16
SENTIMENT_LABELS=negative,neutral,positive,improvement,question

# Data Pipeline
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# Social Media APIs (optional)
FACEBOOK_ACCESS_TOKEN=
YOUTUBE_API_KEY=
INSTAGRAM_ACCESS_TOKEN=

# Dashboard
STREAMLIT_PORT=8501
DASHBOARD_LANGUAGE=ar
REVIEW_DATA_PATH=

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
